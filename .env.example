# OpenAI API key for AI-powered validation and actions.
# Get yours at https://platform.openai.com/api-keys
# If not set, the app falls back to high-quality mock responses.
OPENAI_API_KEY=sk-...

# Stripe (for Pro plan checkout)
# Get these from https://dashboard.stripe.com
#
# 1. Create a product called "Idea → Income Pro"
# 2. Add a recurring price: RM29/month (MYR, monthly)
# 3. Copy the Price ID (starts with price_)
# 4. Copy your Secret Key (starts with sk_test_ or sk_live_)
#
# If not set, the app falls back to email capture instead of checkout.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...

# Supabase (for auth and persistent data)
# Get these from https://supabase.com → Project → Settings → API
#
# 1. Create a new Supabase project
# 2. Run supabase/schema.sql in the SQL Editor
# 3. Enable Google OAuth: Auth → Providers → Google
# 4. Enable Email OTP: Auth → Providers → Email (magic link)
# 5. Add redirect URL: https://your-domain.com/auth/callback
#
# If not set, the app works fully with localStorage only.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
