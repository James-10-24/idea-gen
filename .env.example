# OpenAI API key for AI-powered validation and actions.
# Get yours at https://platform.openai.com/api-keys
# If not set, the app falls back to high-quality mock responses.
OPENAI_API_KEY=sk-...

# Stripe (for Pro plan checkout)
# Get these from https://dashboard.stripe.com
#
# 1. Create a product called "Idea → Income Pro"
# 2. Add a recurring price: RM29/month (MYR, monthly)
# 3. Copy the Price ID (starts with price_)
# 4. Copy your Secret Key (starts with sk_test_ or sk_live_)
#
# If not set, the app falls back to email capture instead of checkout.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
